# Application
APP_NAME=MedVoice AI HMS
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Database (SQLAlchemy 2 async, asyncpg driver)
DATABASE_URL=postgresql+asyncpg://medvoice:medvoice@localhost:5432/medvoice-ai

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Refresh token cookie
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
REFRESH_TOKEN_COOKIE_DOMAIN=
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax

# Password hashing
BCRYPT_ROUNDS=12
